{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "node",
		"baseUrl": "..",
		"outDir": "./dist/", /* Redirect output structure to the directory. */
		"paths": {
			"dom-native": [
				"./dom-native/src/index.ts"
			],
			"@dom-native/draggable": [
				"./draggable/src/index.ts"
			],
			"@dom-native/ui": [
				"./dom-native-ui/src/index.ts"
			]
		},
		"allowJs": false,
		"checkJs": false,
		"strict": true,
		"removeComments": false,
		"sourceMap": true,
		"esModuleInterop": true,

		"experimentalDecorators": true // for now, until rolldown support stage 3
	},
	"include": [
		"./src/**/*.ts",
		"../dom-native/src/**/*.ts",
		"../draggable/src/**/*.ts",
		"../dom-native-ui/src/**/*.ts"
	],
	"exclude": [
		"node_modules",
		".rpt2_cache"
	]
}

