{
  "name": "dom-native",
  "version": "0.11.5",
  "description": "A Native Web Component TypeScript Optimized Utility (zero dependency, < 20kb min, < 7kb gzip)",
  "author": "Jeremy Chone <jeremy.chone@gmail.com> (http://jeremychone.com)",
  "license": "MIT OR Apache-2.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "prepack": "npm run build",
    "build": "rolldown -c",
    "watch": "rolldown -c -w"
  },
  "imports": {
    "#dom-native": "./src/index.js"
  },
  "devDependencies": {
    "rolldown": "^1.0.0-rc.8"
  },
  "files": [
    "src/",
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/dom-native/dom-native.git"
  },
  "keywords": [
    "domnative",
    "dom native",
    "frameworkless",
    "framework",
    "Web Components",
    "Native Web Components",
    "customElements",
    "cssGrid",
    "DOM",
    "mvc",
    "html5"
  ]
}
